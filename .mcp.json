{
  "mcpServers": {
    "indusk": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@infinitedusky/indusk-mcp",
        "serve"
      ],
      "env": {
        "PROJECT_ROOT": "."
      }
    },
    "codegraphcontext": {
      "type": "stdio",
      "command": "cgc",
      "args": [
        "mcp",
        "start"
      ],
      "env": {
        "DATABASE_TYPE": "falkordb-remote",
        "FALKORDB_HOST": "falkordb.orb.local",
        "FALKORDB_GRAPH_NAME": "infinitedusky"
      }
    }
  }
}