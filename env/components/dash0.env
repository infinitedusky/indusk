[default]
TOKEN=${secrets.DASH0_AUTH_TOKEN}
RUM_TOKEN=${secrets.DASH0_RUM_AUTH_TOKEN}
DATASET=indusk-test
HTTP_ENDPOINT=https://ingress.europe-west4.gcp.dash0.com
JSON_LOGS_ENDPOINT=https://ingress.europe-west4.gcp.dash0.com/logs/json
OTLP_HEADERS=Authorization=Bearer ${secrets.DASH0_AUTH_TOKEN},Dash0-Dataset=${dash0.DATASET}
OLTP_ENDPOINT=https://ingress.europe-west4.gcp.dash0.com
API_ENDPOINT=https://api.europe-west4.gcp.dash0.com