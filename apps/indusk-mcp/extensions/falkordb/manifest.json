{
	"name": "falkordb",
	"description": "FalkorDB graph database — shared global instance for code graph via OrbStack",
	"provides": {
		"health_checks": [
			{
				"name": "falkordb-container",
				"command": "docker ps --filter name=falkordb --format '{{.Status}}'"
			},
			{
				"name": "falkordb-connection",
				"command": "node -e \"const s=require('net').connect(6379,process.env.FALKORDB_HOST||'falkordb.orb.local');s.setTimeout(3000);s.on('connect',()=>{console.log('connected');s.end();process.exit(0)});s.on('error',e=>{console.error(e.message);process.exit(1)});s.on('timeout',()=>{console.error('timeout');process.exit(1)})\""
			}
		],
		"env_vars": {
			"FALKORDB_HOST": "falkordb.orb.local"
		}
	},
	"hooks": {
		"on_init": "docker start falkordb 2>/dev/null || docker run -d --name falkordb --restart unless-stopped -v falkordb-global:/var/lib/falkordb/data falkordb/falkordb:latest",
		"on_health_check": "docker ps --filter name=falkordb --format '{{.Status}}'"
	}
}
